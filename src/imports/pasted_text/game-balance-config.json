// Constantes
const BASE_HP = 75;
const DMG_BASE = { easy: 30, medium: 50, hard: 75 };

// Classe do monstro
class Monster {
  type: "weak" | "normal" | "strong" | "boss";
  hp: number;

  constructor(type: Monster["type"]) {
    this.type = type;
    this.hp = BASE_HP * this.getTypeMultiplier();
  }

  private getTypeMultiplier(): number {
    switch (this.type) {
      case "weak": return 1;
      case "normal": return 1.5;
      case "strong": return 2;
      case "boss": return 3.5;
    }
  }
}

// Classe do jogador
class Player {
  level: number = 1;

  calculateDamage(taskDifficulty: keyof typeof DMG_BASE): number {
    const baseDamage = DMG_BASE[taskDifficulty];
    return baseDamage * (1 + this.level * 0.02);
  }
}

